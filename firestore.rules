rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write for RSVP and organizer collections
    match /{collectionName}/{documentId=**} {
      allow read, write: if collectionName.matches('rsvp-.*')
        || collectionName.matches('invitees-.*')
        || collectionName.matches('tables-.*');
    }

    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
